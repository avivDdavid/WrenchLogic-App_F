# ============================================================
#  WrenchLogic-App — repository root ignore rules
#  The actual app lives in wrench-logic/ ; SQL scripts live here.
# ============================================================

# ---- Dependencies & build output (matched at any depth) ----
node_modules/
dist/
dist-ssr/

# ---- Environment variables (Supabase keys — never commit) ----
.env
.env.local
.env.*.local

# ---- Supabase CLI temp (contains DB connection string) ----
.temp/

# ---- Local backup copy — not part of the project ----
wrench-logic-backup-*/

# ---- Misc build log & meaningless root-level lockfile stub ----
/build_output.txt
/package-lock.json

# ---- Claude Code machine-local settings (keep launch.json, drop the rest) ----
settings.local.json

# ---- Logs ----
*.log
npm-debug.log*

# ---- OS / editor cruft ----
.DS_Store
*.suo
*.sw?
